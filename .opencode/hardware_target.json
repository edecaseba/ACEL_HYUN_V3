{
  "_comment": "ARCHIVO DE CONFIGURACIÓN DEL MICROCONTROLADOR ACTIVO",
  "_instruccion": "Todos los agentes leen este archivo antes de actuar. Para cambiar de MCU: modificá 'active_target' y completá el perfil correspondiente en 'targets'.",

  "active_target": "arduino_nano_atmega328p",

  "targets": {

    "arduino_nano_atmega328p": {
      "label": "Arduino Nano — ATmega328P",
      "mcu": "ATmega328P",
      "framework": "arduino",
      "platform": "atmelavr",
      "toolchain": "avr-gcc",
      "clock_mhz": 16,
      "memory": {
        "flash_kb": 31.5,
        "sram_bytes": 2048,
        "eeprom_bytes": 1024,
        "bootloader_kb": 0.5
      },
      "platformio_env": {
        "board": "nanoatmega328new",
        "framework": "arduino",
        "upload_protocol": "arduino",
        "monitor_speed": 115200,
        "build_flags": ["-std=c++20", "-Wall", "-Wextra"],
        "lib_deps": ["EEPROM"]
      },
      "coding_rules": {
        "file_extension": ".cpp / .h  (NUNCA .ino)",
        "timing": "millis() / micros() — sin delay()",
        "memory": "Zero Dynamic RAM post-init — sin String, new, malloc",
        "isr_variables": "volatile obligatorio",
        "standard": "MISRA C++:2008 — static_cast, llaves obligatorias, tipos fijos <cstdint>",
        "watchdog": "wdt_enable(WDTO_2S) en setup(), wdt_reset() en loop()"
      },
      "pins": {
        "PIN_POT_OP":    "A0 — Potenciómetro pedal operador",
        "PIN_POT_FEED":  "A1 — Potenciómetro feedback actuador",
        "PIN_IS_SENSE":  "A2 — Sensor corriente IS del BTS7960",
        "PIN_EN":        "D8 — Enable del puente H",
        "PIN_L_PWM":     "D9 — PWM canal izquierdo (Timer1)",
        "PIN_R_PWM":     "D10 — PWM canal derecho (Timer1)"
      },
      "peripherals": {
        "motor_driver": "IBT-2 (BTS7960) — 24Vcc — H-Bridge",
        "motor_type": "DC brushed — cuerpo de aceleración",
        "machine": "Excavadora Hyundai R250 LC7"
      },
      "test_framework": "Unity + ArduinoFake (PlatformIO native env)",
      "src_dir": "src/",
      "test_dir": "test/"
    },

    "esp32s3_espidf": {
      "label": "ESP32-S3 — ESP-IDF",
      "mcu": "ESP32-S3",
      "framework": "espidf",
      "platform": "espressif32",
      "toolchain": "xtensa-esp32s3-elf-gcc",
      "clock_mhz": 240,
      "memory": {
        "flash_kb": 8192,
        "sram_bytes": 524288,
        "psram_bytes": 0
      },
      "platformio_env": {
        "board": "esp32-s3-devkitc-1",
        "framework": "espidf",
        "upload_protocol": "esptool",
        "monitor_speed": 115200,
        "build_flags": ["-std=c++20"],
        "lib_deps": []
      },
      "coding_rules": {
        "file_extension": ".cpp / .h",
        "timing": "vTaskDelay() / esp_timer_get_time() — sin delay()",
        "memory": "Heap permitido para init — preferir static en tasks",
        "isr_variables": "volatile + portENTER_CRITICAL()",
        "standard": "MISRA C++:2008 adaptado — static_cast, llaves, tipos fijos",
        "rtos": "FreeRTOS — tasks con xTaskCreatePinnedToCore(), colas con xQueueCreate()",
        "watchdog": "esp_task_wdt_init() + esp_task_wdt_add()"
      },
      "pins": {
        "_nota": "Completar pines al migrar. Verificar conflictos con USB/JTAG en ESP32-S3.",
        "PIN_POT_OP":   "GPIO1  — ADC1_CH0 (ejemplo — verificar)",
        "PIN_POT_FEED": "GPIO2  — ADC1_CH1 (ejemplo — verificar)",
        "PIN_IS_SENSE": "GPIO3  — ADC1_CH2 (ejemplo — verificar)",
        "PIN_EN":       "GPIO4  — Enable puente H",
        "PIN_L_PWM":    "GPIO5  — LEDC canal 0",
        "PIN_R_PWM":    "GPIO6  — LEDC canal 1"
      },
      "peripherals": {
        "motor_driver": "IBT-2 (BTS7960) — 24Vcc — H-Bridge",
        "pwm_peripheral": "LEDC (LED Control) — reemplaza analogWrite()",
        "adc_note": "ADC2 no disponible con WiFi activo. Usar ADC1."
      },
      "migration_notes": [
        "analogWrite() → ledcWrite() con ledcSetup() + ledcAttachPin()",
        "EEPROM → NVS (nvs_flash_init, nvs_open, nvs_set_i16)",
        "avr/wdt.h → esp_task_wdt.h",
        "Timer1 (TCCR1A/B) → esp_timer o LEDC timer",
        "loop() bloqueante → task de FreeRTOS en Core 1",
        "Serial → ESP_LOGI / ESP_LOGE con log tags"
      ],
      "test_framework": "ESP-IDF Unity (idf_component_register con TEST_COMPONENTS)",
      "src_dir": "main/",
      "test_dir": "test/"
    }
  }
}
